          "assignments": [
            {
              "id": "b9dd8449-c530-402b-aa7d-f8d73e28a611",
              "name": "type",
              "value": "={{ ($json.output.match(/Clocked\\s+(In|Out)/) || [])[1].toLowerCase() || null  }}",
              "type": "string"
            },
            {
              "id": "520f1385-58ce-4d9f-af18-376d88530ad9",
              "name": "date",
              "value": "={{\n(() => {\n\t// Grab \"Jul 11, 2025\" after the word “at”\n\tconst m = $json.output.match(/at\\s+([A-Za-z]{3}\\s+\\d{1,2},\\s+\\d{4})/);\n\tif (!m) return '';\n\n\t// Use Luxon (built into n8n) for re‑formatting\n\treturn DateTime\n\t\t.fromFormat(m[1], 'LLL d, yyyy')   // parse \"Jul 11, 2025\"\n\t\t.toFormat('dd-MM-yyyy');           // → \"11-07-2025\"\n})()\n}}",
              "type": "string"
            },
            {
              "id": "663397d1-2aa4-4ca1-ad51-a008b895abe4",
              "name": "time",
              "value": "={{\n(() => {\n\t// Grab \"01:55 PM\" that follows the date\n\tconst m = $json.output.match(/at\\s+[A-Za-z]{3}\\s+\\d{1,2},\\s+\\d{4}\\s+(\\d{2}:\\d{2}\\s+[AP]M)/);\n\treturn m ? m[1] : '';\n})()\n}}",
              "type": "string"
            },
            {
              "id": "1dbbe8e9-9066-4e4e-a7aa-04b1483192f4",
              "name": "match_key",
              "value": "={{ \n  (() => {\n    const slackId = $('Execute Workflow').item.json.slackID\n\n    const m = $json.output.match(/at\\s+([A-Za-z]{3}\\s+\\d{1,2},\\s+\\d{4})/);\n    if (!m) return `${slackId}-`; // return partial if date not found\n\n    const dateFormatted = DateTime\n      .fromFormat(m[1], 'LLL d, yyyy')\n      .toFormat('dd-MM-yyyy');\n\n    return `${slackId}-${dateFormatted}`;\n  })()\n}}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
