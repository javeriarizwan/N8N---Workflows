    {
      "parameters": {
        "content": "## Slack Response Parser \nReceives and parses payloads from Slack block actions, capturing user responses from interactive messages (e.g., “Yes” or “No” button clicks).",
        "height": 272,
        "width": 288,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        -2256,
        816
      ],
      "typeVersion": 1,
      "id": "bb0d2cd8-c21c-4d46-b6a7-1faad0b6f212",
      "name": "Sticky Note10"
    },
    {
      "parameters": {
        "content": "## Parse Slack Action Payload \nExtracts and separates the username and action value from the Slack button payload for downstream processing.",
        "height": 272,
        "width": 336,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        -1920,
        816
      ],
      "typeVersion": 1,
      "id": "a3574ae4-495a-4fe5-91f3-c5c6c64e09b1",
      "name": "Sticky Note11"
    },
    {
      "parameters": {
        "jsCode": "// Extract the payload string from incoming data\nconst payloadStr = $input.first().json.body.payload;\n\n// Parse the JSON string into an object\nconst payload = JSON.parse(payloadStr);\n\n// Extract full action value\nconst fullValue = payload.actions[0].value;\n\n// Find the index of \"Subject\"\nconst subjectIndex = fullValue.indexOf(\"Subject\");\n\n// Initialize username and actionValue\nlet username = \"\";\nlet actionValue = fullValue;\n\nif (subjectIndex !== -1) {\n  // Extract everything before \"Subject\" as username, trim to clean spaces\n  username = fullValue.substring(0, subjectIndex).trim();\n\n  // Extract from \"Subject\" onwards as actionValue\n  actionValue = fullValue.substring(subjectIndex).trim();\n}\n\n// Return useful info in a new JSON object for further processing\nreturn [{\n  json: {\n    action_id: payload.actions[0].action_id,\n    action_value: actionValue,\n    user_id: payload.user.id,\n    user_name: username,\n    channel_id: payload.channel.id,\n    message_ts: payload.message.ts,\n    response_url: payload.response_url\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1840,
