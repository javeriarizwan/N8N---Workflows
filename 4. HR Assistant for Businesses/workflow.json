      "typeVersion": 1,
      "id": "9d917490-3890-496c-8d59-3e4c0928a014",
      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const data = JSON.parse(item.json.output);\n\n  // Initialize fields\n  item.json.eventName = \"\";\n  item.json.teamMessage = \"\";\n  item.json.clientMessage = \"\";\n  item.json.eventDay = \"\";\n\n  let event = null;\n\n  // Check if it's a public holiday event\n  if (data.publicHolidayEvents && data.publicHolidayEvents.length > 0) {\n    event = data.publicHolidayEvents[0];\n  }\n  // Or check internal event\n  else if (data.internalEvents && data.internalEvents.length > 0) {\n    event = data.internalEvents[0];\n  }\n\n  // If event exists, populate fields\n  if (event) {\n    item.json.eventName = event[\"Event Name\"] || \"\";\n    item.json.teamMessage = event.teamMessage || \"\";\n    item.json.eventDay = event[\"Day\"] || \"\";\n\n    // Only assign clientMessage if the event is NOT on Saturday or Sunday\n    const day = (event[\"Day\"] || \"\").toLowerCase();\n    if (day !== \"saturday\" && day !== \"sunday\") {\n      item.json.clientMessage = event.clientMessage || \"\";\n    }\n  }\n\n  // Optional: remove original output field if not needed\n  // delete item.json.output;\n}\n\nreturn $input.all();\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
