    {
      "parameters": {
        "content": "## HR Assistant System \nActs as the core decision-maker. It uses the connected OpenAI Chat Model and event data to process which events need reminders and which actions to take.",
        "height": 352,
        "width": 304,
        "color": 6
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        -1952,
        80
